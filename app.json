{
  "expo": {
    "name": "vessel-inspections",
    "slug": "vessel-inspections",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vesselinspections",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.hlag.vesselinspections",
      "infoPlist": {
        "UIBackgroundModes": ["processing"],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.expo.modules.backgroundtask.processing"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hlag.vesselinspections"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Vessel Inspections to use your location to record where inspections take place."
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      "expo-background-task",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vessel Inspections to access your photos to attach them to inspection reports.",
          "cameraPermission": "Allow Vessel Inspections to access your camera to take inspection photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
